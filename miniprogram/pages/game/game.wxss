page {
  background: linear-gradient(180deg, #F8FAFC 0%, #EFF6FF 100%);
  min-height: 100vh;
}
.container { padding: 32rpx; }
.status-bar {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 24rpx;
}
.card { margin-bottom: 32rpx; }
.role-label { font-size: 26rpx; color: #64748B; display: block; margin-bottom: 12rpx; }
.role-value { font-size: 52rpx; font-weight: 800; color: #6366F1; display: block; margin-bottom: 16rpx; }
.instruction {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.6;
  display: block;
  padding: 20rpx;
  background: #F1F5F9;
  border-radius: 12rpx;
}
.question { font-size: 36rpx; font-weight: 700; color: #1E293B; margin-bottom: 24rpx; display: block; }
.definition-hint { font-size: 28rpx; color: #10B981; background: #ECFDF5; padding: 16rpx; border-radius: 8rpx; margin-bottom: 24rpx; display: block; }
.status-text { font-size: 32rpx; color: #6366F1; text-align: center; display: block; padding: 40rpx 0; }
.vote-title { font-size: 34rpx; font-weight: 700; color: #6366F1; margin-bottom: 16rpx; display: block; }
.hint { font-size: 26rpx; color: #94A3B8; margin-bottom: 20rpx; display: block; }
.result-title { font-size: 34rpx; font-weight: 700; color: #6366F1; margin-bottom: 24rpx; display: block; }
.result-card text { font-size: 30rpx; line-height: 1.8; white-space: pre-wrap; }
