<view class="container">
  <view class="status-bar">
    <text>房间：{{roomId}}</text>
    <text>第 {{round}}/{{totalRounds}} 回合</text>
  </view>

  <view class="card" wx:if="{{role}}">
    <text class="role-label">你的身份</text>
    <text class="role-value">{{role}}</text>
    <text class="instruction" wx:if="{{role==='瞎掰王'}}">
      你需要根据题目编一个看起来很真的答案，骗过别人！
    </text>
    <text class="instruction" wx:if="{{role==='大聪明'}}">
      你是大聪明，公开身份。听完所有人作答后，找出老实人。
    </text>
    <text class="instruction" wx:if="{{role==='老实人'}}">
      你是老实人，你看到了正确解释。请不要暴露身份！
    </text>
  </view>

  <view class="card" wx:if="{{question && !submitted}}">
    <text class="question">题目：{{question}}</text>
    <text class="definition-hint" wx:if="{{role==='老实人'}}">正确定义：{{honestAnswer}}</text>
    <textarea placeholder="{{role==='大聪明' ? '等待玩家提交...' : '输入你的答案...'}}" value="{{draft}}" bindinput="onDraft" disabled="{{role==='大聪明'}}" />
    <button type="primary" bindtap="submitAnswer" disabled="{{role==='大聪明'}}">
      {{role==='大聪明' ? '等待中' : '提交答案'}}
    </button>
  </view>

  <view class="card" wx:if="{{submitted && role!=='大聪明'}}">
    <text class="status-text">✅ 已提交，等待大聪明投票</text>
  </view>

  <view class="card" wx:if="{{role==='大聪明' && allSubmitted}}">
    <text class="vote-title">投票环节</text>
    <text class="hint">选择你认为的老实人：</text>
    <radio-group bindchange="onVote">
      <label wx:for="{{players}}" wx:key="id">
        <radio value="{{item.id}}" disabled="{{item.id===userId}}" />
        <text>{{item.nickname}} {{item.id===userId?'(你自己)':''}}</text>
      </label>
    </radio-group>
    <button type="primary" bindtap="castVote">投票</button>
  </view>

  <view class="card result-card" wx:if="{{roundEnded}}">
    <text class="result-title">回合结果</text>
    <text>{{resultMessage}}</text>
    <button type="primary" bindtap="nextRound" wx:if="{{hasNext}}">下一回合</button>
    <button type="primary" bindtap="endGame" wx:else>查看最终排名</button>
  </view>
</view>
